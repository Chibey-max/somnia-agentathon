# AgentWallet deployment config (Sepolia)

# Guardian controls pause/unpause, limits, and whitelist policy
GUARDIAN_ADDRESS=0x

# Agent is the only role allowed to call execute()
AGENT_ADDRESS=0x

# Optional human-readable policy values for your notes
ETH_TX_LIMIT=0.1
ETH_DAILY_LIMIT=0.5

# Deployer private key (funded on Sepolia)
PRIVATE_KEY=0x
