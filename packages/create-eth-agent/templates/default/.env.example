# ── Required ─────────────────────────────────────────────────
# Your deployed AgentWallet contract on Sepolia
AGENT_CONTRACT_ADDRESS=

# The agent role private key (NOT your guardian/personal key)
# This address must match the agent role in your AgentWallet contract
AGENT_PRIVATE_KEY=

# Sepolia RPC — free options (no account needed):
#   https://rpc.ankr.com/eth_sepolia
#   https://sepolia.drpc.org
#   https://ethereum-sepolia-rpc.publicnode.com
RPC_URL=https://rpc.ankr.com/eth_sepolia

# AI providers (at least one required)
# Groq (recommended, free): console.groq.com
GROQ_API_KEY=
# OpenRouter (free models): openrouter.ai
OPENROUTER_API_KEY=
# Google Gemini (free tier): aistudio.google.com
GOOGLE_API_KEY=

# ── Optional ──────────────────────────────────────────────────
CHAIN_ID=11155111
GUARDIAN_ADDRESS=
