{
  "context_servers": {
    "eth-agent": {
      "command": "npm",
      "args": ["run", "-s", "mcp"]
    }
  },
  "lsp": {
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore"
          }
        },
        "scss": {
          "lint": {
            "unknownAtRules": "ignore"
          }
        },
        "less": {
          "lint": {
            "unknownAtRules": "ignore"
          }
        }
      }
    }
  }
}
