# AgentWallet deployment config (Somnia Testnet)

# Guardian controls pause/unpause, limits, and whitelist policy
GUARDIAN_ADDRESS=0x

# Agent is the only role allowed to call execute()
AGENT_ADDRESS=0x

# Optional human-readable policy values for your notes
STT_TX_LIMIT=0.1
STT_DAILY_LIMIT=0.5

# Deployer private key (funded on Somnia Testnet)
PRIVATE_KEY=0x

# Somnia Testnet RPC
RPC_URL=https://dream-rpc.somnia.network
CHAIN_ID=50312
