# Signer boundary configuration
# Default local mode (development): uses AGENT_PRIVATE_KEY in-process
SIGNER_MODE=local

# Proxy mode (production): signs out-of-process via signer service/KMS/HSM
# SIGNER_MODE=proxy
# SIGNER_PROXY_URL=https://your-signer.example.com/v1/execute
# SIGNER_PROXY_TOKEN=replace-with-bearer-token
