# ── Blockchain ────────────────────────────────────────────
# Your deployed AgentWallet contract address on Sepolia
AGENT_CONTRACT_ADDRESS=0x

# The AGENT role private key (not the guardian key)
# This address must match the agent role set in your AgentWallet contract
# Get Sepolia ETH: https://sepoliafaucet.com
AGENT_PRIVATE_KEY=0x

# Sepolia RPC URL — free options (pick one):
# https://rpc.ankr.com/eth_sepolia          ← no account needed
# https://eth-sepolia.g.alchemy.com/v2/KEY  ← alchemy.com free tier
# https://sepolia.drpc.org                  ← no account needed
RPC_URL=https://rpc.ankr.com/eth_sepolia

# ── AI Provider ───────────────────────────────────────────
# Free at console.groq.com — used for the agent's LLM
GROQ_API_KEY=

# ── Optional ──────────────────────────────────────────────
# Chain ID (default: 11155111 = Sepolia testnet)
CHAIN_ID=11155111

# Guardian address — only needed for dashboard guardian panel
GUARDIAN_ADDRESS=0x
