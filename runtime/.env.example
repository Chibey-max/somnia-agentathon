# ── Blockchain ────────────────────────────────────────────
# Your deployed AgentWallet contract address on Somnia Testnet
AGENT_CONTRACT_ADDRESS=0x65479a6491061d1c0D7200292Da83f4D48Fc12f7

# The AGENT role private key (not the guardian key)
# This address must match the agent role set in your AgentWallet contract
# Get STT from the Somnia faucet: https://testnet.somnia.network
AGENT_PRIVATE_KEY=0x

# Somnia Testnet RPC URL (no account needed)
RPC_URL=https://dream-rpc.somnia.network

# ── AI Provider ───────────────────────────────────────────
# Free at console.groq.com — used for the agent's LLM
GROQ_API_KEY=

# ── Optional ──────────────────────────────────────────────
# Chain ID (default: 50312 = Somnia Testnet)
CHAIN_ID=50312

# Guardian address — only needed for dashboard guardian panel
GUARDIAN_ADDRESS=0x

# Trusted recipient for token transfers
TRUSTED_RECIPIENT=0x

# Terminal 3 Network — get your key at terminal3.io/claim-page
T3N_API_KEY=
